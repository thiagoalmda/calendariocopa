# Copie este arquivo para .env e preencha com sua chave.
#
# 1) Cadastro gratuito da chave (leva ~1 minuto):
#    https://www.football-data.org/client/register
# 2) Cole a chave gerada em FOOTBALL_DATA_TOKEN abaixo.
# 3) Pronto — `python main.py` busca os jogos atualizados e gera o .ics.

FOOTBALL_DATA_TOKEN=

# Competição na football-data.org. Deixe "WC" (FIFA World Cup) para a Copa.
FOOTBALL_DATA_COMPETITION=WC

# Temporada (ano do início). Deixe vazio para a temporada vigente da API.
FOOTBALL_DATA_SEASON=2026

# Identificador usado no UID dos eventos. Mantenha estável entre execuções
# para que o Google Agenda atualize os eventos em vez de duplicar.
CALENDAR_NAMESPACE=worldcup-2026@calendariocopa
